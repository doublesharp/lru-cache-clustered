{
  "name": "lru-cache-for-clusters-as-promised",
  "version": "2.0.0",
  "description": "LRU Cache that is safe for clusters, based on lru-cache. Save memory by only caching items on the main thread via a promisified interface.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsup",
    "test": "node --import tsx --test test/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov --include='src/**/*.ts' pnpm test",
    "lint": "eslint --no-error-on-unmatched-pattern src test",
    "format": "prettier --write src test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test && pnpm lint && pnpm typecheck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doublesharp/lru-cache-for-clusters-as-promised.git"
  },
  "keywords": [
    "lru",
    "mru",
    "cache",
    "lru-cache",
    "cluster",
    "promise",
    "typescript",
    "ipc"
  ],
  "author": "Justin Silver",
  "license": "MIT",
  "dependencies": {
    "debug": "^4.4.3",
    "lru-cache": "^11.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "c8": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
