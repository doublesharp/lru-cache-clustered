{
  "name": "lru-cache-for-clusters-as-promised",
  "version": "2.0.0",
  "description": "LRU Cache that is safe for clusters, based on lru-cache. Save memory by only caching items on the main thread via a promisified interface.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "test": "node --import tsx --test test/*.test.ts",
    "test:fuzz": "node --import tsx --test test/*.fuzz.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov --include='src/**/*.ts' pnpm test",
    "lint": "eslint --no-error-on-unmatched-pattern src test",
    "format": "prettier --write src test",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "size": "size-limit",
    "type-coverage": "type-coverage --at-least 99",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm knip && pnpm type-coverage",
    "prepublishOnly": "pnpm build && pnpm test && pnpm lint && pnpm typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": "prettier --write",
    "*.ts": "eslint --fix"
  },
  "size-limit": [
    {
      "name": "esm",
      "path": "dist/index.js",
      "limit": "5 KB",
      "brotli": true
    },
    {
      "name": "cjs",
      "path": "dist/index.cjs",
      "limit": "5 KB",
      "brotli": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doublesharp/lru-cache-for-clusters-as-promised.git"
  },
  "keywords": [
    "lru",
    "mru",
    "cache",
    "lru-cache",
    "cluster",
    "promise",
    "typescript",
    "ipc"
  ],
  "author": "Justin Silver",
  "license": "MIT",
  "dependencies": {
    "debug": "^4.4.3",
    "lru-cache": "^11.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@size-limit/file": "^12.1.0",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "c8": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "type-coverage": "^2.29.7",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
